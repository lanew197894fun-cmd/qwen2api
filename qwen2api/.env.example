
# 如果需要修改Docker暴露埠，請修改ports中的引數
# 示例(8080:3000) 則訪問 http://localhost:8080
# To change the exposed Docker port, modify the ports parameter
# Example: (8080:3000) then access http://localhost:8080
SERVICE_PORT=3000


# 監聽地址(非必填)
# Listen address (optional)
LISTEN_ADDRESS=

# PM2 多程序配置
# PM2程序數量配置
# max: 使用所有CPU核心
# 數字: 指定程序數量，如 4
# 1: 單程序模式
# PM2 multi-process configuration
# max: use all CPU cores
# number: specify process count, e.g. 4
# 1: single process mode
PM2_INSTANCES=1

# PM2記憶體限制，超過此限制將自動重啟程序
# 支援格式: 100M, 1G, 2G 等
# PM2 memory limit — process restarts when exceeded
# Supported formats: 100M, 1G, 2G, etc.
PM2_MAX_MEMORY=1G

# API 金鑰配置
# 支援單個或多個API_KEY，用逗號分隔
# 第一個API_KEY為管理員金鑰，擁有全部許可權（可訪問前端管理頁面、修改設定）
# 其他API_KEY為普通金鑰，僅有呼叫API的許可權，不能訪問前端管理頁面
#
# API key configuration
# Supports single or multiple API_KEYs, comma-separated
# The first API_KEY is the admin key with full access (dashboard, settings)
# Other API_KEYs are regular keys with API-only access (no dashboard)
#
# 單個金鑰示例 / Single key example:
# API_KEY=sk-admin123
#
# 多個金鑰示例 / Multiple keys example:
# API_KEY=sk-admin123,sk-user456,sk-user789
# 其中 / Where:
# - sk-admin123: 管理員金鑰 / admin key (dashboard + settings + API)
# - sk-user456,sk-user789: 普通金鑰 / regular keys (API only)
API_KEY=sk-123456

# 是否輸出思考過程
# Whether to output the thinking process
OUTPUT_THINK=true

# 搜尋資訊顯示模式
# Search info display mode
SEARCH_INFO_MODE=table

# 簡化模型對映
# true: 只返回基礎模型，不包含thinking、search、image等變體
# false: 返回完整模型列表，包含所有變體
# Simplified model mapping
# true: only base models, without thinking/search/image variants
# false: full model list with all variants
SIMPLE_MODEL_MAP=false

# Redis連結(如果使用redis模式,則必填,當redis使用tls時將redis://替換為rediss://)
# Redis URL (required for redis mode; use rediss:// for TLS)
REDIS_URL=

# 批次新增賬號時的登入併發數
# 建議範圍 1-20，預設 5
# Batch login concurrency when adding accounts
# Recommended range: 1-20, default: 5
BATCH_LOGIN_CONCURRENCY=5

# 資料儲存模式
# none 不儲存資料，僅使用環境變數中的設定
# file 儲存在本地檔案中
# redis 儲存到遠端/本地redis中
# Data save mode
# none — no persistence, use env vars only
# file — save to local file
# redis — save to remote/local Redis
DATA_SAVE_MODE=none

# 賬號與密碼用 : 分隔，賬號與賬號間用 , 分隔（如果使用 redis / file 模式則不需要填寫）
# 可選：在密碼後用 | 附加該賬號專屬的代理 URL，覆蓋全域性 PROXY_URL
# Accounts — email:password pairs, comma-separated (not needed for redis/file mode)
# Optional: append |proxy_url after the password to set a per-account proxy
#           overriding the global PROXY_URL fallback below
# 示例 / Examples:
#   ACCOUNTS=user1@mail.com:pass1,user2@mail.com:pass2
#   ACCOUNTS=user1@mail.com:pass1|http://10.0.0.1:8080,user2@mail.com:pass2|socks5://10.0.0.2:1080
ACCOUNTS=

# 日誌配置
# 日誌級別 (DEBUG, INFO, WARN, ERROR)
# Logging configuration
# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# 是否啟用檔案日誌
# Enable file logging
ENABLE_FILE_LOG=false

# 日誌檔案目錄
# Log file directory
LOG_DIR=./logs

# 最大日誌檔案大小 (MB)
# Max log file size (MB)
MAX_LOG_FILE_SIZE=10

# 保留的日誌檔案數量
# Number of log files to retain
MAX_LOG_FILES=5

# ========== 代理與反代配置 / Proxy & Reverse Proxy ==========

# 自定義反代URL配置
# Custom reverse proxy URL
# QWEN_CHAT_PROXY_URL: 替代 https://chat.qwen.ai 的反代地址
# QWEN_CHAT_PROXY_URL: replaces https://chat.qwen.ai
# 示例 / Example: QWEN_CHAT_PROXY_URL=https://your-proxy.com
QWEN_CHAT_PROXY_URL=

# QWEN_CLI_PROXY_URL: 替代 https://portal.qwen.ai 的反代地址
# QWEN_CLI_PROXY_URL: replaces https://portal.qwen.ai
# 示例 / Example: QWEN_CLI_PROXY_URL=https://your-cli-proxy.com
QWEN_CLI_PROXY_URL=

# HTTP/HTTPS 代理配置
# 支援 HTTP, HTTPS, SOCKS5 代理
# 全域性回退代理：當賬號未配置專屬代理時使用（賬號級代理可在 dashboard 或 ACCOUNTS 中設定）
# 優先順序：account.proxy > PROXY_URL > 不使用代理
# HTTP/HTTPS proxy configuration
# Supports HTTP, HTTPS, SOCKS5 proxies
# Global fallback proxy — used only when an account has no dedicated proxy
# (per-account proxy can be set via the dashboard or ACCOUNTS env var)
# Priority: account.proxy > PROXY_URL > no proxy
# 示例 / Example: PROXY_URL=http://127.0.0.1:7890
# 示例 / Example: PROXY_URL=socks5://127.0.0.1:1080
PROXY_URL=
